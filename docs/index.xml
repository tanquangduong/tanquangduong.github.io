<span id="cb12-2"><span class="ex" style="color: null;
background-color: null;
font-style: inherit;">├──</span> Modelfile</span>
<span id="cb12-3"><span class="ex" style="color: null;
background-color: null;
font-style: inherit;">├──</span> model.gguf</span></code></pre></div></div>
</section>
<section id="create-modelfile" class="level3">
<h3 class="anchored" data-anchor-id="create-modelfile">Create Modelfile</h3>
<div class="code-copy-outer-scaffold"><div class="sourceCode" id="cb13" style="background: #f1f3f5;"><pre class="sourceCode txt code-with-copy"><code class="sourceCode default"><span id="cb13-1">FROM ./model.gguf</span>
<span id="cb13-2"></span>
<span id="cb13-3">SYSTEM You are a helpful AI assistant.</span>
<span id="cb13-4"></span>
<span id="cb13-5">PARAMETER temperature 0.7</span>
<span id="cb13-6">PARAMETER num_ctx 2048</span></code></pre></div></div>
</section>
<section id="run-model" class="level3">
<h3 class="anchored" data-anchor-id="run-model">Run Model</h3>
<div class="code-copy-outer-scaffold"><div class="sourceCode" id="cb14" style="background: #f1f3f5;"><pre class="sourceCode bash code-with-copy"><code class="sourceCode bash"><span id="cb14-1"><span class="ex" style="color: null;
background-color: null;
font-style: inherit;">ollama</span> create my-model <span class="at" style="color: #657422;
background-color: null;
font-style: inherit;">-f</span> Modelfile</span>
<span id="cb14-2"><span class="ex" style="color: null;
background-color: null;
font-style: inherit;">ollama</span> run my-model</span></code></pre></div></div>
</section>
<section id="api-usage" class="level3">
<h3 class="anchored" data-anchor-id="api-usage">API Usage</h3>
<div class="code-copy-outer-scaffold"><div class="sourceCode" id="cb15" style="background: #f1f3f5;"><pre class="sourceCode python code-with-copy"><code class="sourceCode python"><span id="cb15-1"><span class="im" style="color: #00769E;
background-color: null;
font-style: inherit;">import</span> requests</span>
<span id="cb15-2"></span>
<span id="cb15-3">response <span class="op" style="color: #5E5E5E;
background-color: null;
font-style: inherit;">=</span> requests.post(</span>
<span id="cb15-4">    <span class="st" style="color: #20794D;
background-color: null;
font-style: inherit;">"http://localhost:11434/api/generate"</span>,</span>
<span id="cb15-5">    json<span class="op" style="color: #5E5E5E;
background-color: null;
font-style: inherit;">=</span>{</span>
<span id="cb15-6">        <span class="st" style="color: #20794D;
background-color: null;
font-style: inherit;">"model"</span>: <span class="st" style="color: #20794D;
background-color: null;
font-style: inherit;">"my-model"</span>,</span>
<span id="cb15-7">        <span class="st" style="color: #20794D;
background-color: null;
font-style: inherit;">"prompt"</span>: <span class="st" style="color: #20794D;
background-color: null;
font-style: inherit;">"Explain LoRA"</span>,</span>
<span id="cb15-8">        <span class="st" style="color: #20794D;
background-color: null;
